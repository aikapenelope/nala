# Nova - Local development environment variables.
# Copy this file to .env and adjust values as needed.

# PostgreSQL (Docker Compose default)
DATABASE_URL=postgresql://nova:nova@localhost:5432/nova

# Redis (Docker Compose default)
REDIS_URL=redis://localhost:6379

# MinIO (Docker Compose default)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=nova
MINIO_SECRET_KEY=novapassword
MINIO_USE_SSL=false

# API port
PORT=3001

# Clerk auth (required)
# Get keys from https://dashboard.clerk.com -> API Keys
NUXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
NUXT_CLERK_SECRET_KEY=sk_test_your_key_here
# Same secret key for the API backend
CLERK_SECRET_KEY=sk_test_your_key_here

# CORS: comma-separated list of allowed origins
# CORS_ORIGIN=https://nova.aikalabs.cc

# Tenant subdomain domain (for subdomain-per-tenant routing)
# In production: the dedicated domain (e.g., novapp.com)
# In development: localhost (subdomain detection disabled by default)
# NUXT_PUBLIC_TENANT_DOMAIN=novapp.com
# TENANT_DOMAIN=novapp.com

# OpenRouter (for AI narratives in reports)
# OPENROUTER_API_KEY=

# Groq fallback (for AI narratives)
# GROQ_API_KEY=
