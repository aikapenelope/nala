# Nova - Local development environment variables.
# Copy this file to .env and adjust values as needed.

# PostgreSQL (Docker Compose default)
DATABASE_URL=postgresql://nova:nova@localhost:5432/nova

# Redis (Docker Compose default)
REDIS_URL=redis://localhost:6379

# MinIO (Docker Compose default)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=nova
MINIO_SECRET_KEY=novapassword
MINIO_USE_SSL=false

# API port
PORT=3001

# Clerk (configure when setting up auth in Phase 1)
# CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# OpenRouter (configure when setting up AI in Phase 5)
# OPENROUTER_API_KEY=

# Groq fallback (configure when setting up AI in Phase 5)
# GROQ_API_KEY=

# WhatsApp Cloud API (configure in Phase 7)
# WA_PHONE_NUMBER_ID=
# WA_ACCESS_TOKEN=
# WA_VERIFY_TOKEN=
